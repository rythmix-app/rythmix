{
  "expo": {
    "name": "front-mobile",
    "slug": "front-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ios-dark.png",
    "splash": {
      "image": "./assets/images/ios-dark.png",
      "resizeMode": "contain",
      "backgroundColor": "#343434"
    },
    "scheme": "frontmobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.frontmobile",
      "infoPlist": {

        "UIBackgroundModes": [
          "audio",
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-dark.png",
        "backgroundColor": "#343434"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.frontmobile",
      "permissions": [
        "INTERNET",
        "MODIFY_AUDIO_SETTINGS",
        "WAKE_LOCK",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#343434",
          "image": "./assets/images/logo-rythmix-light.png",
          "imageWidth": 200,
          "ios": {
            "image": "./assets/images/ios-dark.png"
          },
          "android": {
            "image": "./assets/images/android-dark.png",
            "adaptiveIcon": {
              "foregroundImage": "./assets/images/android-dark.png",
              "backgroundColor": "#343434"
            }
          }
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "160a02f5-15f4-41a9-bdd9-e402672188b0"
      }
    },
    "owner": "aldo26",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/160a02f5-15f4-41a9-bdd9-e402672188b0"
    }
  }
}
